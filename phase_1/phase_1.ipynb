      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Deep search manual cari duplicate dan anomali lain"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# No self-transaction, no duplikat baris(cek manual), no ID collision C/M \n",
        "\n",
        "# Ga ada transaksi dari pengirim ke penerima yang sama (self-transaction)\n",
        "self_transaction = df[df['nameOrig'] == df['nameDest']]\n",
        "print(f\"Jumlah: {len(self_transaction)}\")\n",
        "\n",
        "# Ga ada duplikat baris (cek manual) di step + type + nameOrig + nameDest + oldbalanceOrg\n",
        "dup_cols = ['step', 'type', 'nameOrig', 'nameDest', 'oldbalanceOrg']\n",
        "duplicates = df[df.duplicated(subset=dup_cols, keep=False)]\n",
        "print(f\"Jumlah baris duplikat: {len(duplicates)}\")\n",
        "\n",
        "# Cek distribusi karakter pertama dari nameOrig dan nameDest\n",
        "print(df['nameOrig'].str[0].value_counts())\n",
        "print(df['nameDest'].str[0].value_counts())\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Cek negative values"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# no negative values\n",
        "\n",
        "neg_check = df[(df['amount']<0) | (df['oldbalanceOrg']<0) | (df['newbalanceOrig']<0) | (df['oldbalanceDest']<0) | (df['newbalanceDest']<0)]\n",
        "print(len(neg_check))"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Cek anomali step unique"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step kontinu 1-743, gap di 744 cuma karena ujung periode, bukan data hilang\n",
        "\n",
        "missing_steps = set(range(1,745)) - set(df['step'].unique())\n",
        "print(f\"Step yang hilang: {missing_steps}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Analisis kenapa balance di payment dan sebagian Cash_Out 0"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Balance 0→0 massal di PAYMENT/sebagian CASH_OUT — merchant gak punya balance tercatat\n",
        "# ini buang semua yang stuck di angka kecil/0, dan cuma sisain yang stuck di angka besar (di atas 1000). \n",
        "# Logikanya: kalau balance kamu 5 juta terus abis transfer 5 juta tetep tercatat 5 juta, itu aneh \n",
        "# beda sama kalau balance kamu 0 dan abis bayar tetep 0 (itu mah emang gak ada uangnya dari awal).\n",
        "\n",
        "relevant_types = df[df['type'].isin(['PAYMENT', 'TRANSFER', 'CASH_OUT'])]\n",
        "stuck_balance = relevant_types[relevant_types['oldbalanceOrg'] == relevant_types['newbalanceOrig']]\n",
        "print(stuck_balance['type'].value_counts())\n",
        "print(stuck_balance[['oldbalanceOrg', 'newbalanceOrig']].describe())\n",
        "\n",
        "# → Hasil: 2.082.846 baris, median 0→0, breakdown CASH_OUT/PAYMENT/TRANSFER\n",
        "# Dikonfirmasi lebih lanjut dengan PAYMENT sum check: Hasil: 2.151.495, match persis sama jumlah nameDest prefix M\n",
        "\n",
        "print((df['type'] == 'PAYMENT').sum())"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Tentuin anomali dari Anomali formula balance (newbalance ≠ oldbalance ± amount) di TRANSFER/CASH_OUT "
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Anomali formula matematis balance (66-80% baris) — by-design, bukan corrupt\n",
        "# Hasil: 79,81% origin, 65,83% dest\n",
        "\n",
        "df['expected_new_orig'] = df['oldbalanceOrg'] - df['amount']\n",
        "df['diff_orig'] = df['newbalanceOrig'] - df['expected_new_orig']\n",
        "df['expected_new_dest'] = df['oldbalanceDest'] + df['amount']\n",
        "df['diff_dest'] = df['newbalanceDest'] - df['expected_new_dest']\n",
        "\n",
        "anomali_orig = df[df['diff_orig'].abs() > 0.01]\n",
        "anomali_dest = df[df['diff_dest'].abs() > 0.01]\n",
        "\n",
        "print(f\"Anomali balance origin: {len(anomali_orig)} ({len(anomali_orig)/len(df)*100:.2f}%)\")\n",
        "print(f\"Anomali balance dest: {len(anomali_dest)} ({len(anomali_dest)/len(df)*100:.2f}%)\")\n",
        "\n",
        "# Hasil: CASH_OUT 545 + TRANSFER 4.095 = 4.640 dari total 8.213 fraud (~56%)\n",
        "# dari semua 8.213 kasus fraud di seluruh dataset, 4.640 di antaranya (56%) punya ciri \"balance penerima gak sesuai formula matematis\". \n",
        "# Artinya kalau kamu pakai kondisi anomali_dest sebagai filter/fitur, dia bakal \"nangkep\" lebih dari separuh kasus fraud yang ada\n",
        "\n",
        "print(pd.crosstab(anomali_dest['type'], anomali_dest['isFraud']))"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Cek Balance penerima justru berkurang padahal dia menerima uang dan Balance pengirim justru bertambah padahal dia mengirim uang"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Sinyal lemah — H4 & H5\n",
        "# H5 (orig naik) exclude CASH_IN\n",
        "# Hasil: 2 baris, CASH_OUT, non-fraud\n",
        "\n",
        "orig_increased = df[(df['newbalanceOrig'] > df['oldbalanceOrg']) & (df['amount'] > 0)]\n",
        "orig_increased_no_cashin = orig_increased[orig_increased['type'] != 'CASH_IN']\n",
        "print(len(orig_increased_no_cashin))\n",
        "print(orig_increased_no_cashin['type'].value_counts())\n",
        "print(orig_increased_no_cashin['isFraud'].value_counts())\n",
        "\n",
        "print(\"================================\")\n",
        "\n",
        "# H4 (dest turun) exclude CASH_IN\n",
        "# Hasil: 44.385 baris, tapi cuma 27 fraud (0,06%)\n",
        "\n",
        "dest_decreased = df[(df['newbalanceDest'] < df['oldbalanceDest']) & (df['amount'] > 0)]\n",
        "dest_decreased_no_cashin = dest_decreased[dest_decreased['type'] != 'CASH_IN']\n",
