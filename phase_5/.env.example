# Salin berkas ini jadi ".env" (atau export manual sbg environment variable)
# kalau ingin mengubah pengaturan default.

# URL Elasticsearch. Default sudah benar kalau memakai docker-compose.yml
# yang disertakan (port 9200 di localhost).
ELASTICSEARCH_URL=http://localhost:9200

# Paksa backend tertentu, kosongkan utk mode otomatis (coba Elasticsearch dulu,
# fallback ke DuckDB). Isi "duckdb" utk selalu pakai DuckDB walau Elasticsearch menyala.
FANCE_BACKEND=

# Folder tempat berkas fance_dashboard.duckdb & manifest.json disimpan/dibaca.
FANCE_DATA_DIR=./data

# Port & mode Dash (app.py membacanya lewat os.environ)
PORT=8050
DASH_DEBUG=false
